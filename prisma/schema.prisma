generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ProviderType {
  SALON
  PRIVATE
  INDIVIDUAL
}

enum ProfileStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  SUSPENDED
}

enum BookingStatus {
  LOCKED
  PENDING
  CONFIRMED
  CANCELED
  COMPLETED
  NO_SHOW
}

enum BookingCanceledBy {
  CLIENT
  MASTER
  SYSTEM
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  icon        String?
  form_schema Json
  profiles    Profile[]
  translations CategoryTranslation[]
}

model CategoryTranslation {
  id                  Int      @id @default(autoincrement())
  categoryId          Int      @map("category_id")
  locale              String   @db.VarChar(8)
  name                String
  translationSource   String   @default("original") @map("translation_source")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  category            Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@index([locale])
  @@map("category_translations")
}

model Profile {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  user_id     String?   @unique
  user_email  String    @unique
  name        String
  provider_type ProviderType @default(PRIVATE)
  city        String
  address     String?
  category_id Int
  attributes  Json
  image_url   String?
  gallery     String[]  @default([])
  studioImages String[] @default([])
  languages   String[]  @default([])
  bio         String?  @db.Text
  originalLocale String @default("ru") @map("original_locale") @db.VarChar(8)
  phone       String?
  telegramChatId String?
  latitude    Float?
  longitude   Float?
  schedule    Json?
  status      ProfileStatus @default(PENDING_REVIEW)
  onboardingStep Int        @default(1)
  providesInStudio Boolean  @default(true)
  providesOutcall  Boolean  @default(false)
  outcallRadiusKm  Int?
  is_verified Boolean   @default(false)

  // Arrival info for Private Masters — revealed post-booking only
  // JSON structure: { address: string, doorCode?: string, bellNote?: string, waitingSpot?: string }
  arrivalInfo  Json?
  onboardingCompleted Boolean @default(false)

  created_at  DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  user        User?     @relation(fields: [user_id], references: [id], onDelete: SetNull)
  category    Category  @relation(fields: [category_id], references: [id])
  services    Service[]
  translations ProfileTranslation[]
  bookings    Booking[]
  conversations Conversation[]
  favorites   Favorite[] @relation("ProviderFavorited")
  staff       Staff[]
  reviews     Review[]
  telegramTokens TelegramToken[]
  photos      PortfolioPhoto[]
  clients     Client[]

  @@index([category_id])
}

model ProfileTranslation {
  id                  Int      @id @default(autoincrement())
  profileId           Int      @map("profile_id")
  locale              String   @db.VarChar(8)
  bio                 String?  @db.Text
  translationSource   String   @default("machine") @map("translation_source")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  profile             Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, locale])
  @@index([locale])
  @@map("profile_translations")
}

model Service {
  id           Int     @id @default(autoincrement())
  profile_id   Int
  title        String
  description  String?
  images       String[] @default([])
  price        Decimal @db.Decimal(10, 2)
  duration_min Int
  originalLocale String @default("ru") @map("original_locale") @db.VarChar(8)

  profile      Profile @relation(fields: [profile_id], references: [id])
  translations ServiceTranslation[]
  bookings     Booking[]
  photos       PortfolioPhoto[]
  staff        Staff[] @relation("ServiceStaff")

  @@index([profile_id])
}

model ServiceTranslation {
  id                  Int      @id @default(autoincrement())
  serviceId           Int      @map("service_id")
  locale              String   @db.VarChar(8)
  title               String
  description         String?
  translationSource   String   @default("machine") @map("translation_source")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  service             Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, locale])
  @@index([locale])
  @@map("service_translations")
}

model Booking {
  id          Int      @id @default(autoincrement())
  profile_id  Int
  service_id  Int?
  user_id     String?
  staff_id    String?
  date        DateTime
  time        String
  user_name   String
  user_phone  String
  user_email  String?
  status      BookingStatus      @default(PENDING)
  canceledBy  BookingCanceledBy?
  isManual    Boolean            @default(false)
  slotLock    String?            @unique
  lockExpiresAt DateTime?
  otpSessionId  String?
  reviewRequestedAt DateTime?
  created_at  DateTime           @default(now())

  user        User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)
  profile     Profile  @relation(fields: [profile_id], references: [id])
  service     Service? @relation(fields: [service_id], references: [id])
  staff       Staff?   @relation(fields: [staff_id], references: [id], onDelete: SetNull)
  review      Review?

  @@index([profile_id])
  @@index([user_id])
  @@index([staff_id])
  @@index([profile_id, date, status])
  @@index([status, lockExpiresAt])
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  role          Role      @default(USER)
  isBanned      Boolean   @default(false)
  isShadow      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  bio           String?

  // --- Onboarding fields ---
  providerType         ProviderType @default(PRIVATE)
  companyName          String?
  isKleinunternehmer   Boolean      @default(false)
  taxId                String?
  address              String?
  city                 String?
  zipCode              String?
  onboardingCompleted  Boolean      @default(false)
  onboardingType       String?

  // --- Subscription & Billing (hidden, for future Stripe integration) ---
  subscriptionPlan      String    @default("FREE")
  stripeCustomerId      String?   @unique
  stripeSubscriptionId  String?   @unique
  isGrandfathered       Boolean   @default(false)

  // --- Legal & DAC7 Compliance (hidden) ---
  agbAcceptedAt         DateTime?
  agbAcceptedIp         String?
  legalAddress          String?
  legalName             String?
  legalEntityType       String?
  vatId                 String?

  profile       Profile?
  accounts      Account[]
  sessions      Session[]
  bookings      Booking[]
  conversationsAsClient Conversation[] @relation("ClientConversations")
  favorites     Favorite[] @relation("UserFavorites")
  sentMessages  Message[]
  reviews       Review[]
}

model Staff {
  id         String   @id @default(cuid())
  profileId  Int
  name       String
  avatarUrl  String?
  bio        String?
  schedule   Json?
  specialty  String?
  experience String?
  rating     Float    @default(5.0)
  tags       String[] @default([])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  profile       Profile             @relation(fields: [profileId], references: [id], onDelete: Cascade)
  bookings      Booking[]
  photos        PortfolioPhoto[]
  availability  StaffAvailability[]
  services      Service[]           @relation("ServiceStaff")

  @@index([profileId])
}

model StaffAvailability {
  id        String   @id @default(cuid())
  staffId   String
  dayOfWeek Int
  startTime String
  endTime   String
  isWorking Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, dayOfWeek])
  @@index([staffId])
}

model PortfolioPhoto {
  id        String   @id @default(cuid())
  url       String
  profileId Int
  serviceId Int?
  staffId   String?
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  staff     Staff?   @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@index([profileId])
  @@index([serviceId])
  @@index([staffId])
  @@index([profileId, serviceId])
}

model Conversation {
  id              String    @id @default(cuid())
  clientUserId    String
  providerProfileId Int
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  clientUser      User      @relation("ClientConversations", fields: [clientUserId], references: [id], onDelete: Cascade)
  providerProfile Profile   @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)
  messages        Message[]

  @@unique([clientUserId, providerProfileId])
  @@index([clientUserId])
  @@index([providerProfileId])
  @@index([updatedAt])
}

model Message {
  id              String      @id @default(cuid())
  conversationId  String
  senderUserId    String
  content         String
  isRead          Boolean     @default(false)
  createdAt       DateTime    @default(now())

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUser      User         @relation(fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderUserId])
}

model Account {
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model OtpVerification {
  id        String   @id @default(cuid())
  email     String
  code      String                // bcrypt-hashed 6-digit code
  expiresAt DateTime
  attempts  Int      @default(0)  // max 5 before invalidation
  verified  Boolean  @default(false)
  bookingId Int?                  // links to the LOCKED booking
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([email, code])
  @@index([expiresAt])
}

model Favorite {
  id                 String   @id @default(cuid())
  clientId           String
  providerProfileId  Int
  createdAt          DateTime @default(now())

  client   User    @relation("UserFavorites", fields: [clientId], references: [id], onDelete: Cascade)
  provider Profile @relation("ProviderFavorited", fields: [providerProfileId], references: [id], onDelete: Cascade)

  @@unique([clientId, providerProfileId])
  @@index([clientId])
  @@index([providerProfileId])
}

model Review {
  id          String    @id @default(cuid())
  profileId   Int
  clientId    String
  bookingId   Int       @unique
  comment     String?   @db.Text
  rating      Int       // 1–5
  replyText   String?   @db.Text
  repliedAt   DateTime?
  createdAt   DateTime  @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  client  User    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([clientId])
  @@index([createdAt])
}

model Client {
  id             String   @id @default(cuid())
  profileId      Int
  name           String
  phone          String
  email          String?
  totalBookings  Int      @default(0)
  totalSpent     Decimal  @default(0) @db.Decimal(12, 2)
  noShows        Int      @default(0)
  lastVisit      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, phone])
  @@index([profileId])
  @@index([profileId, lastVisit])
}

model TelegramToken {
  id        String   @id @default(cuid())
  token     String   @unique
  profileId Int
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([profileId])
  @@index([expiresAt])
}
