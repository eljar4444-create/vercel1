# Database
DATABASE_URL="postgresql://..."

# Auth (NextAuth v5) — обязателен для входа в том числе через Google
# Сгенерировать: openssl rand -base64 33
AUTH_SECRET="your-secret-at-least-32-chars"

# JWT для API-регистрации и входа (email/password). Минимум 16 символов.
# Сгенерировать: openssl rand -base64 24
JWT_SECRET="your-jwt-secret-at-least-16-chars"

# Для локальной разработки (опционально, если редиректы ломаются)
# AUTH_URL="http://localhost:3000"

# Google OAuth (вход через Google)
# Создайте OAuth 2.0 Client ID в Google Cloud Console.
# В «Authorized redirect URIs» добавьте: http://localhost:3000/api/auth/callback/google
# В «Authorized JavaScript origins» добавьте: http://localhost:3000
GOOGLE_CLIENT_ID="..."
GOOGLE_CLIENT_SECRET="..."

# Vercel Blob
# Для production-загрузок изображений укажите read/write token.
# Локально без этого токена приложение сохранит файлы в public/uploads/.
BLOB_READ_WRITE_TOKEN="..."

# Telegram bot
TELEGRAM_BOT_USERNAME="your_bot_username"
TELEGRAM_WEBHOOK_SECRET="generate-a-long-random-secret"
